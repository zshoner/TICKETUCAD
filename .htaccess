RewriteEngine On
RewriteBase /TICKETUCAD/

# ── Página 404 personalizada ──────────────────────────────────────────────────
ErrorDocument 404 /TICKETUCAD/app/views/errors/404.html

# Ocultar versión de Apache
ServerSignature Off

# ── 3. Bloquear acceso directo a vistas HTML ──────────────────────────────────
# La protección real es view.php (verifica sesión). Aquí bloqueamos navegación
# directa desde fuera del dominio o sin referer.
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteCond %{HTTP:X-Requested-With} !XMLHttpRequest [NC]
RewriteCond %{HTTP_REFERER} !^http://localhost/TICKETUCAD/ [NC]
RewriteRule ^app/views/(pages|forms)/.+\.html$ - [R=404,L]

# ── 4. Bloquear acceso directo a PHP del backend ─────────────────────────────
# Los fetch() del front pasan normalmente (no mandan Accept: text/html).
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteCond %{HTTP:X-Requested-With} !XMLHttpRequest [NC]
RewriteCond %{HTTP_REFERER} !^http://localhost/TICKETUCAD/ [NC]
RewriteRule ^app/models/.+\.php$ - [R=404,L]

# ── 5. Redirigir raíz al login ────────────────────────────────────────────────
RewriteRule ^$ inicio-sesion [R=302,L]

# ── 6. Rutas amigables ────────────────────────────────────────────────────────
RewriteRule ^inicio-sesion/?$       app/router/view.php?view=login            [L,NC]
RewriteRule ^panel-administrador/?$ app/router/view.php?view=padmin            [L,NC]
RewriteRule ^formulario-usuario/?$  app/router/view.php?view=form_user         [L,NC]
RewriteRule ^reportes-sistema/?$    app/router/view.php?view=reportes          [L,NC]
RewriteRule ^admin-usuarios/?$      app/router/view.php?view=usuarios          [L,NC]
RewriteRule ^configuraciones/?$     app/router/view.php?view=configuracion     [L,NC]
RewriteRule ^cambiar-password/?$    app/router/view.php?view=cambiar_password  [L,NC]
RewriteRule ^vista-ticket/?$        app/router/view.php?view=vista_ticket      [L,NC]

# Compatibilidad con rutas antiguas
RewriteRule ^pages/vista_ticket\.html$   app/router/view.php?view=vista_ticket [L,NC]
RewriteRule ^pages/vista-ticket\.html$   app/router/view.php?view=vista_ticket [L,NC]
RewriteRule ^pages/vista%20ticket\.html$ app/router/view.php?view=vista_ticket [L,NC]
