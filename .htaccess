RewriteEngine On
RewriteBase /TICKETUCAD/

# Redirigir raíz al login
RewriteRule ^$ inicio-sesion [R=302,L]

# Ruta amigable para el login
RewriteRule ^inicio-sesion/?$ app/views/pages/login.html [L,NC]

# Ruta amigable para el panel de administrador
RewriteRule ^panel-administrador/?$ app/views/pages/padmin.html [L,NC]

# Ruta amigable para formulario
RewriteRule ^formulario-usuario/?$ app/views/forms/form_user.html [L,NC]

# Ruta amigable para evitar la redirección al generar reportes
RewriteRule ^reportes-sistema/?$ app/views/pages/reportes.html [L,NC]

# Ruta amigable para administración de usuarios
RewriteRule ^admin-usuarios/?$ app/views/pages/usuarios.html [L,NC]

# Ruta amigable para configuraciones
RewriteRule ^configuraciones/?$ app/views/pages/configuraciones.html [L,NC]
# Ruta amigable para cambiar contraseña
RewriteRule ^cambiar-password/?$ app/views/pages/cambiar_password.html [L,NC]

# Ruta amigable para vista detalle de ticket
RewriteRule ^vista-ticket/?$ app/views/pages/vista_ticket.html [L,NC]

# Compatibilidad con rutas antiguas de detalle
RewriteRule ^pages/vista_ticket\.html$ app/views/pages/vista_ticket.html [L,NC]
RewriteRule ^pages/vista-ticket\.html$ app/views/pages/vista_ticket.html [L,NC]
RewriteRule ^pages/vista%20ticket\.html$ app/views/pages/vista_ticket.html [L,NC]